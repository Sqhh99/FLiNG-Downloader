// RC constants (avoid dependency on windows.h / winres.h for Ninja builds)
#ifndef VS_VERSION_INFO
#define VS_VERSION_INFO 1
#endif

// Application icon
IDI_ICON1 ICON "@APP_ICON_RC_PATH@"

// Version info resource
VS_VERSION_INFO VERSIONINFO
FILEVERSION @APP_VERSION_FILE_COMMA@
PRODUCTVERSION @APP_VERSION_FILE_COMMA@
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "FLiNG Downloader Project"
            VALUE "FileDescription", "FLiNG Downloader - Game Modifier Download Manager"
            VALUE "FileVersion", "@APP_VERSION@"
            VALUE "InternalName", "FLiNG Downloader"
            VALUE "LegalCopyright", "Copyright (C) 2024. Licensed under GNU AGPL v3."
            VALUE "OriginalFilename", "FLiNG Downloader.exe"
            VALUE "ProductName", "FLiNG Downloader"
            VALUE "ProductVersion", "@APP_VERSION@"
            VALUE "Comments", "Open source game modifier download manager. Visit https://github.com/Sqhh99/FLiNG-Downloader"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
